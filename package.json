{
  "name": "equatoria-idle",
  "version": "0.1.0",
  "description": "Equatoria Idle — a mobile-first idle game with equation progression and gem particles",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "predev": "node scripts/generate-boss-music-track-manifest.mjs",
    "prebuild": "node scripts/generate-boss-music-track-manifest.mjs",
    "prebuild:desktop": "node scripts/generate-boss-music-track-manifest.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:desktop": "tsc --noEmit && vite build --mode desktop",
    "postbuild:desktop": "node scripts/copy-assets.mjs",
    "electron": "electron .",
    "desktop": "npm run build:desktop && electron .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src",
    "preview": "vite preview",
    "postbuild": "node scripts/copy-assets.mjs",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build": "npm run build && npx cap sync android && cd android && gradlew.bat bundleRelease"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sethrimer3/Equatoria_Idle.git"
  },
  "keywords": [
    "idle",
    "game",
    "math",
    "equation"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sethrimer3/Equatoria_Idle/issues"
  },
  "homepage": "https://github.com/sethrimer3/Equatoria_Idle#readme",
  "devDependencies": {
    "electron": "^38.5.0",
    "eslint": "^10.2.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@capacitor/android": "8.4.0",
    "@capacitor/cli": "8.4.0",
    "@capacitor/core": "8.4.0"
  }
}
