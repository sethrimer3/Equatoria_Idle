# Copy this file to android/keystore.properties and fill in your real values.
# NEVER commit keystore.properties to version control.
#
# Generate a new keystore (one-time setup):
#   keytool -genkey -v -keystore android/release.keystore \
#           -alias equatoria -keyalg RSA -keysize 2048 -validity 10000
#
# Store the keystore file AND this file's passwords somewhere safe
# (password manager, CI secret store) — losing them means you cannot
# update your app on the Play Store.

# Path to the keystore file, relative to the android/app/ directory
storeFile=../release.keystore

# The alias you chose when running keytool -genkey (-alias flag)
keyAlias=equatoria

# The store password (-storepass / entered interactively during keytool)
storePassword=YOUR_STORE_PASSWORD

# The key password (-keypass / entered interactively during keytool)
# Can be the same as storePassword
keyPassword=YOUR_KEY_PASSWORD
